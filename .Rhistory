sp.occur <- occ_data(scientificName = "Vultur gryphus",
hasCoordinate = TRUE,
limit = 5000)
sp.occur <- data.frame(sp.occur$data)
sp.occur <- subset(sp.occur, institutionCode != "iNaturalist")
map("world", xlim=c(-85, -60), ylim=c(-58, 15))
map.axes()
points(sp.occur$decimalLatitude ~ sp.occur$decimalLongitude)
sp.occur.vect <- vect(x=sp.occur, geom=c("decimalLongitude", "decimalLatitude"),
crs=crs("epsg:4326"))
# Note I'm still using resolution 2.5' to save time (both downloading the
# climate and running the models). For the final project you *might* want
# to switch to finer scale data (e.g. res = 0.5)
climate <- worldclim_global(var = "bio", res = 2.5, download = T, path="data")
plot(climate[[1]])
points(sp.occur.vect)
# Project occurrence points to UTM (or whichever projection is best)
sp.occur.utm <- project(sp.occur.vect, "ESRI:102033")
# Buffer
# Note: some versions of terra have been having problems with this buffer
# line of code. If you get an error about a "ptr", please do the following:
# 1. Click Session -> Restart R
# 2. Run the following commands:
#       unlink(".Rdata")
#       rm(list=ls())
#       install.packages("terra")
# 3. Go back to the top to load packages and start again. I think that
#     will fix this problem
buffer.utm <- terra::buffer(sp.occur.utm, width=1000000)
buffer.utm <- aggregate(buffer.utm)
plot(buffer.utm)
points(sp.occur.utm)
# And project the buffer back into Lat/Lon to match the climate layers
buffer.wgs <- project(buffer.utm, sp.occur.vect)
subset.clim <- climate[[c(1,4,12,14,15)]]
plot(subset.clim)
# "Crop" the raster so it's got the same extent as the buffer
crop.clim <- terra::crop(subset.clim, buffer.wgs)
plot(crop.clim[[1]])
# And "mask" it so that the outline is the same
final.clim <- terra::mask(crop.clim, buffer.wgs)
plot(final.clim[[1]])
plot(buffer.wgs, add=T)
points(sp.occur.vect)
# Buffer
# Note: some versions of terra have been having problems with this buffer
# line of code. If you get an error about a "ptr", please do the following:
# 1. Click Session -> Restart R
# 2. Run the following commands:
#       unlink(".Rdata")
#       rm(list=ls())
#       install.packages("terra")
# 3. Go back to the top to load packages and start again. I think that
#     will fix this problem
buffer.utm <- terra::buffer(sp.occur.utm, width=500000)
buffer.utm <- aggregate(buffer.utm)
plot(buffer.utm)
points(sp.occur.utm)
# And project the buffer back into Lat/Lon to match the climate layers
buffer.wgs <- project(buffer.utm, sp.occur.vect)
subset.clim <- climate[[c(1,4,12,14,15)]]
plot(subset.clim)
# "Crop" the raster so it's got the same extent as the buffer
crop.clim <- terra::crop(subset.clim, buffer.wgs)
plot(crop.clim[[1]])
# And "mask" it so that the outline is the same
final.clim <- terra::mask(crop.clim, buffer.wgs)
plot(final.clim[[1]])
plot(buffer.wgs, add=T)
points(sp.occur.vect)
tune.args <- list(fc=c("LQHT"),
rm=seq(from=0.5, to=5, by=0.5))
# By default, Maxent splits data into 5 different partitions, but
# for time I'm subsetting to just 3
partition.settings <- list(kfolds = 3)
# Please read through the help file for ENMevaluate so that
# some of this makes more sense!
# This took about 1.5 minutes to run on my laptop.
max.output <- ENMevaluate(occs=crds(sp.occur.vect),
envs=final.clim,
tune.args = tune.args,
algorithm = "maxnet",
partitions = "randomkfold",
partition.settings = partition.settings,
parallel=TRUE)
# Save the results to disk so you don't have to run that again
save(max.output, file="acondor_maxent_model.rda")
# Highest level summary of the models:
max.output
# List of objects you might explore:
str(max.output, max.level=2)
# AIC table comparing models tested (with additional accuracy metrics):
max.output@results
# Plot AIC results across values of the regularization multiplier:
evalplot.stats(e=max.output, stats="AICc", color="fc", x.var="rm")
# Select best model based on top AIC score (in the case I've been
# doing, the model w/ rm = 0.5 had the lowest AIC score):
best.model <- max.output@models$fc.LQHT_rm.0.5
best_model_auc <- max.output@results$auc.val[which.min(max.output@results$AICc)]
print(best_model_auc)
# Select best model based on top AIC score (in the case I've been
# doing, the model w/ rm = 0.5 had the lowest AIC score):
best.model <- max.output@models$fc.LQHT_rm.0.5
# Plot response curves
plot(best.model)
# Plot suitability model
best.model.hsm <- max.output@predictions$fc.LQHT_rm.0.5
par(mfrow=c(1,1))
plot(best.model.hsm)
points(sp.occur.vect, pch=21, col="black", bg="white")
suitability_presences <- terra::extract(best.model.hsm, sp.occur.vect)
background_points <- spatSample(final.clim, size=10000, method="random")
suitability_background <- terra::extract(best.model.hsm, background_points)
if (!require(ecospat)) {
install.packages("ecospat")
library(ecospat)
}
boyce_result <- ecospat.boyce(fit = as.numeric(suitability_background),
obs = as.numeric(suitability_presences))
print(boyce_result$cor)
# Plot response curves
plot(best.model)
suitability_presences <- terra::extract(best.model, sp.occur.vect)
# Plot suitability model
best.model.hsm <- max.output@predictions$fc.LQHT_rm.0.5
par(mfrow=c(1,1))
plot(best.model.hsm)
points(sp.occur.vect, pch=21, col="black", bg="white")
suitability_presences <- terra::extract(best.model.hsm, sp.occur.vect)
suitability_presences <- terra::extract(best.model.hsm, sp.occur.vect)
set.seed(42)  # Ensure reproducibility
background_points <- spatSample(final.clim, size=10000, method="random")
suitability_background <- terra::extract(best.model.hsm, background_points)
# Generate random background points with correct format
set.seed(42)  # Ensure reproducibility
background_points <- spatSample(final.clim[[1]], size=10000, method="random", xy=TRUE)
# Check structure (should have two columns: x and y)
head(background_points)
# Extract suitability values for presence points
suitability_presences <- terra::extract(best.model.hsm, sp.occur.vect)[,2]
# Extract suitability values for background points
suitability_background <- terra::extract(best.model.hsm, background_points)[,2]
head(background_points)
